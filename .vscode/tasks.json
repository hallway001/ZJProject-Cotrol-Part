{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "colcon-build",
            "type": "shell",
            "command": "colcon build --packages-select loader_control",
            "args": [],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "colcon-build-debug",
            "type": "shell",
            "command": "colcon build --packages-select loader_control --cmake-args -DCMAKE_BUILD_TYPE=Debug",
            "args": [],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "colcon-clean",
            "type": "shell",
            "command": "rm -rf build install log",
            "args": [],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "source-ros2",
            "type": "shell",
            "command": "source /opt/ros/humble/setup.bash && source install/setup.bash",
            "args": [],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}

